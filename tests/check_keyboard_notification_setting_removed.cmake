if(NOT DEFINED ONEG4_VOLUME_SOURCE)
    message(FATAL_ERROR "ONEG4_VOLUME_SOURCE is required")
endif()
if(NOT DEFINED ONEG4_VOLUME_CONFIGURATION_SOURCE)
    message(FATAL_ERROR "ONEG4_VOLUME_CONFIGURATION_SOURCE is required")
endif()
if(NOT DEFINED ONEG4_VOLUME_CONFIGURATION_HEADER)
    message(FATAL_ERROR "ONEG4_VOLUME_CONFIGURATION_HEADER is required")
endif()
if(NOT DEFINED ONEG4_VOLUME_CONFIGURATION_UI)
    message(FATAL_ERROR "ONEG4_VOLUME_CONFIGURATION_UI is required")
endif()

file(READ "${ONEG4_VOLUME_SOURCE}" ONEG4_VOLUME_CONTENT)
file(READ "${ONEG4_VOLUME_CONFIGURATION_SOURCE}" ONEG4_VOLUME_CONFIGURATION_CONTENT)
file(READ "${ONEG4_VOLUME_CONFIGURATION_HEADER}" ONEG4_VOLUME_CONFIGURATION_HEADER_CONTENT)
file(READ "${ONEG4_VOLUME_CONFIGURATION_UI}" ONEG4_VOLUME_CONFIGURATION_UI_CONTENT)

string(FIND "${ONEG4_VOLUME_CONTENT}" "showNotification(true)" FORCED_NOTIFICATION_POS)
if(NOT FORCED_NOTIFICATION_POS EQUAL -1)
    message(FATAL_ERROR "Unexpected in-plugin forced notification call remains")
endif()

string(FIND "${ONEG4_VOLUME_CONFIGURATION_HEADER_CONTENT}" "SETTINGS_SHOW_KEYBOARD_NOTIFICATIONS" HEADER_SETTING_POS)
if(NOT HEADER_SETTING_POS EQUAL -1)
    message(FATAL_ERROR "Keyboard-notification setting macro still exists in header")
endif()

string(FIND "${ONEG4_VOLUME_CONFIGURATION_CONTENT}" "showKeyboardNotificationsCheckBox" CPP_WIDGET_POS)
if(NOT CPP_WIDGET_POS EQUAL -1)
    message(FATAL_ERROR "Keyboard-notification checkbox logic still exists in configuration source")
endif()

string(FIND "${ONEG4_VOLUME_CONFIGURATION_UI_CONTENT}" "showKeyboardNotificationsCheckBox" UI_WIDGET_POS)
if(NOT UI_WIDGET_POS EQUAL -1)
    message(FATAL_ERROR "Keyboard-notification checkbox still exists in configuration UI")
endif()
